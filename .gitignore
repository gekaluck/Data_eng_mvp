# =============================================================================
# .gitignore — local-first lakehouse stack (Python / Spark / dbt / Airflow /
# Iceberg / notebooks / IDE)
# =============================================================================

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# --- Environment / secrets --------------------------------------------------
.env
.env.*
!.env.example

# --- Airflow ----------------------------------------------------------------
# Logs are bind-mounted and can grow large; keep the folder, drop the contents.
# (plugins/ is a real Airflow source dir and is intentionally NOT ignored.)
logs/
!logs/.gitkeep

# --- Docker volumes (if they ever leak onto the host) -----------------------
postgres-data/
minio-data/
airflow-logs/

# --- Spark / Iceberg local warehouse ----------------------------------------
spark-warehouse/
metastore_db/
derby.log
*.crc
.ivy2/

# --- dbt --------------------------------------------------------------------
.dbt/
dbt/dbt_packages/
dbt/logs/
dbt/target/
dbt/.user.yml

# --- Notebooks --------------------------------------------------------------
.ipynb_checkpoints/

# --- Data files (never commit lakehouse data) -------------------------------
*.parquet
*.avro
*.orc

# --- IDE / editor -----------------------------------------------------------
.vscode/
.idea/
*.swp

# --- OS ---------------------------------------------------------------------
.DS_Store
Thumbs.db

# =============================================================================
# Environment Variables Template
# Copy this file to .env and fill in secure values before starting services.
# =============================================================================

# -----------------------------------------------------------------------------
# Airflow Security
# -----------------------------------------------------------------------------
# Generate with:
#   py -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# Airflow admin user credentials
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Docker/Airflow Configuration
# -----------------------------------------------------------------------------
AIRFLOW_IMAGE_NAME=apache/airflow:2.10.4
AIRFLOW_UID=50000

# -----------------------------------------------------------------------------
# Airflow Metadata DB (Postgres)
# -----------------------------------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=airflow

# Iceberg JDBC catalog databases (shared by Spark, Trino, and dbt)
ICEBERG_CATALOG_HOST=postgres
ICEBERG_CATALOG_PORT=5432
ICEBERG_SILVER_CATALOG_DB=iceberg_silver
ICEBERG_GOLD_CATALOG_DB=iceberg_gold

# -----------------------------------------------------------------------------
# MinIO (S3-compatible Object Storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# CoinCap API
# -----------------------------------------------------------------------------
# Current CoinCap API docs and key signup:
#   https://rest.coincap.io/api-docs
#   https://splash.coincap.io/
COINCAP_API_BASE_URL=https://rest.coincap.io/v3
COINCAP_ASSETS_PATH=/assets
COINCAP_ASSET_HISTORY_PATH_TEMPLATE=/assets/{id}/history
COINCAP_ASSET_MARKETCAP_HISTORY_PATH_TEMPLATE=/assets/{id}/marketcap-history
COINCAP_TOTAL_MARKETCAP_HISTORY_PATH=/assets/totals/total-marketcap-history
COINCAP_API_KEY=REPLACE_WITH_COINCAP_API_KEY

# JupyterLab browser
JUPYTER_TOKEN=REPLACE_WITH_A_LOCAL_TOKEN
